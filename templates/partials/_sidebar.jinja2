<div class="sidebar">
    <div class="logo">
        <img src="/favicon.svg" alt="Axiom Logo" class="logo-img">
        <span class="logo-text">Axiom</span>
    </div>

    <ul class="nav-links">
        {% for item in nav_items %}
        <li class="nav-item">
            <a href="{{ item.url }}" class="nav-link {{ 'active' if active_path == item.url else '' }}">
                {% if item.icon %}
                <img src="{{ item.icon }}" alt="{{ item.name }}">
                {% else %}
                <i>☰</i>
                {% endif %}
                <span>{{ item.name }}</span>
            </a>
        </li>
        {% endfor %}
    </ul>

    <div class="sidebar-footer" style="display: flex; gap: 10px;">
        <button id="theme-toggle" class="settings-btn" title="Toggle Theme">
            <img src="/static/image/icons/light.svg" alt="Toggle Theme" class="theme-icon">
        </button>
        <a href="/settings" class="settings-btn {{ 'active' if active_path == '/settings' else '' }}">
            <img src="/static/image/icons/settings.svg" alt="Settings">
        </a>
    </div>
</div>