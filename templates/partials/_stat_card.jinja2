<div class="stat-card">
    <div class="stat-title">{{ title }}</div>
    <div class="progress-circle">
        <svg viewBox="0 0 100 100">
            <circle class="progress-bg" cx="50" cy="50" r="45"></circle>
            <circle class="progress-ticks" cx="50" cy="50" r="45"></circle>
            {% set radius = 45 %}
            {% set circumference = 282.74 %}
            {% set offset = circumference - (circumference * percentage / 100) %}
            <circle class="progress-value" cx="50" cy="50" r="45" 
                style="stroke-dasharray: {{ circumference }}; stroke-dashoffset: {{ offset }};">
            </circle>
            <circle class="progress-dot" cx="50" cy="50" r="3"
                style="transform-origin: 50px 50px; transform: rotate({{ (percentage * 3.6) }}deg) translate(45px);">
            </circle>
        </svg>
        <div class="progress-text">{{ percentage }}%</div>
    </div>
</div>
