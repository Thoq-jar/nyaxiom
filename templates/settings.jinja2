{% extends "base.jinja2" %}

{% block content %}
<main>
    <h1 class="greeting">Settings</h1>

    <!-- todo: generalize usage of cards (dont use forcast card) -->
    <div class="forecast-card">
        <div class="forecast-header">
            <h2 class="forecast-title">Dashboard Configuration</h2>
        </div>

        <form action="{{ url_for('main.update_settings') }}" method="POST" class="settings-form">
            <div class="input-area">
                <label for="interval" class="settings-input-label">Update
                    Interval (seconds)</label>
                <input type="number" id="interval" name="interval" value="{{ interval }}" min="1" max="60"
                    class="interval-setting">
            </div>

            <button class="settings-submit-button nav-link active" type="submit">
                Save Changes
            </button>
        </form>
    </div>
</main>
{% endblock %}